DATABASE_URL=postgresql+psycopg://trip:trip@postgres:5432/trip
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
JWT_SECRET_KEY=replace-with-at-least-32-random-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
BOOTSTRAP_ADMIN_EMAIL=admin@trip.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_DISPLAY_NAME=System Admin

# TODO(Gecko): 需要你在 Google Cloud Console 申请 OAuth Client ID 后填写。
# 未填写时，Google 登录会返回：未填写Google/Apple Id, bundle id，到 /Users/gecko/trip/.env 内填写完整id
GOOGLE_OAUTH_CLIENT_ID=

# TODO(Gecko): 需要你在 Apple Developer 后台申请 Sign in with Apple Service ID / Client ID 后填写。
# 未填写时，Apple 登录会返回：未填写Google/Apple Id, bundle id，到 /Users/gecko/trip/.env 内填写完整id
APPLE_OAUTH_CLIENT_ID=

# TODO(Gecko): iOS App 使用 Apple 登录时需要填写 Bundle ID。
# 未填写时，Apple 登录会返回：未填写Google/Apple Id, bundle id，到 /Users/gecko/trip/.env 内填写完整id
APPLE_OAUTH_BUNDLE_ID=
